{
  "config": {
    "step": {
      "user": {
        "title": "Настройка бота VK Teams",
        "description": "Введите данные вашего бота из @Metabot",
        "data": {
          "token": "Токен бота",
          "api_url": "URL сервера",
          "parse_mode": "Режим форматирования",
          "poll_interval": "Интервал опроса (секунд)"
        }
      }
    },
    "error": {
      "invalid_auth": "Неверный токен или URL сервера"
    },
    "abort": {
      "already_configured": "Интеграция уже настроена"
    }
  },
  "selector": {
    "parse_mode": {
      "options": {
        "HTML": "HTML",
        "MarkdownV2": "MarkdownV2"
      }
    }
  },
  "config_subentries": {
    "allowed_chat_ids": {
      "step": {
        "user": {
          "title": "Добавить разрешённый чат",
          "description": "Введите ID чата или пользователя\n\n- Для пользователя: user@example.com\n- Для группы: 123456789@chat.agent",
          "data": {
            "chat_id": "ID чата"
          }
        }
      },
      "error": {
        "invalid_chat_id": "Неверный ID чата",
        "chat_not_found": "Чат не найден. Проверьте правильность ID или убедитесь, что бот добавлен в группу"
      }
    }
  },
  "entity": {
    "event": {
      "update_event": {
        "name": "Обновления бота"
      }
    }
  }
}